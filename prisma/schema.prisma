model Reservation {
  id           String   @id @default(cuid())

  productId    String
  warehouseId  String

  quantity     Int

  status       String

  expiresAt    DateTime

  createdAt    DateTime @default(now())

  product       Product
    @relation(fields: [productId], references: [id])

  warehouse     Warehouse
    @relation(fields: [warehouseId], references: [id])
}